EXPO_PUBLIC_API_URL=http://localhost:3001

# Google Maps (Android) — get a key at https://console.cloud.google.com
GOOGLE_MAPS_API_KEY_ANDROID=

# Observability — both are optional; omit to disable in dev
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Feature flags (set to 'false' to disable, omit or set to anything else to enable)
EXPO_PUBLIC_FF_ID_CARD_EMAIL=true
EXPO_PUBLIC_FF_AI_CONCIERGE=true
EXPO_PUBLIC_FF_WELLNESS_WISDOM=true
